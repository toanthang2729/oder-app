rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
             (request.auth.token.email == "toanthang2729@gmail.com");
    }

    function isSuperAdmin() {
      return isAdmin();
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isOwner(restaurantId) {
      return isAuthenticated() && 
             (isSuperAdmin() ||
              get(/databases/$(database)/documents/restaurants/$(restaurantId)).data.ownerUid == request.auth.uid ||
              (getUserData().role == 'owner' && getUserData().restaurantId == restaurantId));
    }

    function hasRole(restaurantId, roles) {
      return isAuthenticated() && 
             (isSuperAdmin() ||
              (getUserData().restaurantId == restaurantId && getUserData().role in roles));
    }

    function isValidUser(data) {
      return data.uid is string &&
             data.phone is string &&
             data.role in ['owner', 'cashier', 'waiter', 'superadmin'];
    }

    function isValidRestaurant(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.ownerUid is string;
    }

    function isValidMenuItem(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.price is number && data.price >= 0 &&
             data.restaurantId is string;
    }

    function isValidOrder(data) {
      return data.restaurantId is string &&
             data.items is list && data.items.size() > 0 &&
             data.total is number && data.total >= 0 &&
             data.status in ['pending', 'cooking', 'ready', 'served', 'paid', 'completed', 'cancelled', 'archived'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || request.auth.uid == userId || getUserData().role == 'owner');
      allow create: if isAuthenticated() && (isSuperAdmin() || request.auth.uid == userId || (getUserData().role == 'owner' && isOwner(request.resource.data.restaurantId))) && isValidUser(request.resource.data);
      allow update: if isAuthenticated() && (isSuperAdmin() || request.auth.uid == userId || (getUserData().role == 'owner' && getUserData().restaurantId == resource.data.restaurantId)) && isValidUser(request.resource.data);
      allow delete: if isSuperAdmin();
    }

    match /restaurants/{restaurantId} {
      allow read: if true;
      allow create: if isAuthenticated() && (isSuperAdmin() || isValidRestaurant(request.resource.data));
      allow update: if isOwner(restaurantId) && isValidRestaurant(request.resource.data);
      allow delete: if isSuperAdmin();
      
      match /menuItems/{itemId} {
        allow read: if true;
        allow write: if isOwner(restaurantId) && isValidMenuItem(request.resource.data);
      }
      
      match /orders/{orderId} {
        allow read: if isOwner(restaurantId) || hasRole(restaurantId, ['cashier', 'waiter']);
        allow create: if isValidOrder(request.resource.data);
        allow update: if (isOwner(restaurantId) || hasRole(restaurantId, ['cashier', 'waiter'])) && 
                      isValidOrder(request.resource.data);
      }
    }
  }
}
