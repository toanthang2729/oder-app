{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with role and restaurant association",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "phone": { "type": "string" },
        "role": { "type": "string", "enum": ["owner", "cashier", "waiter", "superadmin"] },
        "restaurantId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "phone", "role"]
    },
    "Restaurant": {
      "title": "Restaurant",
      "description": "Information about the restaurant",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "ownerUid": { "type": "string" },
        "address": { "type": "string" },
        "plan": { "type": "string", "enum": ["standard", "pro"] },
        "trialEndsAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "ownerUid"]
    },
    "MenuItem": {
      "title": "MenuItem",
      "description": "A dish in the restaurant menu",
      "type": "object",
      "properties": {
        "restaurantId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "imageUrl": { "type": "string" },
        "imageUrls": { "type": "array" },
        "available": { "type": "boolean" }
      },
      "required": ["restaurantId", "name", "price"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order",
      "type": "object",
      "properties": {
        "restaurantId": { "type": "string" },
        "tableNumber": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "cooking", "ready", "served", "paid", "completed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["restaurantId", "items", "total", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and roles"
    },
    "/restaurants/{restaurantId}": {
      "schema": "Restaurant",
      "description": "Restaurant profiles"
    },
    "/restaurants/{restaurantId}/menuItems/{itemId}": {
      "schema": "MenuItem",
      "description": "Menu items for a restaurant"
    },
    "/restaurants/{restaurantId}/orders/{orderId}": {
      "schema": "Order",
      "description": "Orders for a restaurant"
    }
  }
}
